# ============================================================================
# AI Finance Operations Platform — .env.example
#
# Local Docker Compose (accfin/docker-compose.yml):
#   FINANCE_DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/postgres
#   POSTGRES_PASSWORD=postgres
#   FINANCE_REDIS__HOST=redis
# Run: python scripts/generate-keys.py  then merge secrets into .env
# ============================================================================
# mmlogistix
# ============================================================================
#
# Version: 1.8
# Date: 19 May 2026
# Filename: env.example
#
# Version History
# | Version | Date       | Changes |
# |---------|------------|---------|
# | 1.8     | 2026-05-19 | §8b: FINANCE_DAILY_LOG__CSV_UTF8_BOM; daily digest file finance_daily_{date}.csv (email + Wasabi). See 06 §7.4.1, 14 §2.7. |
# | 1.7     | 2026-05-19 | FINANCE_WASABI__* for bucket bp0workacc (logs/, backups/, transactions/). See 14 §2.9, 06 §7.5. |
# | 1.6     | 2026-05-19 | Renumbered duplicate §11: Encryption (§11), Monitoring (§12), Grafana Docker var (§12a); shifted §12–§16 → §13–§17. |
# | 1.4     | 2026-05-19 | FINANCE_DAILY_LOG_RECIPIENT default cfo.mmlogistix@bp0.work (CFO per 01 §3). Hierarchy alignment pass. |
# | 1.3     | 2026-05-19 | FINANCE_DAILY_LOG_RECIPIENT, FINANCE_DAILY_LOG_TIMEZONE (9pm SGT digest). See 14 §2.7, 11 §17.5. |
# | 1.2     | 2026-05-19 | Public hostnames: FINANCE_PUBLIC__* (api, finance, admin UIs, Traefik dashboard) and FINANCE_LETS_ENCRYPT_EMAIL=admin@bp0.work. See 14 §2.7, §9.0. |
# | 1.1     | 2026-05-19 | Ollama/Hermes: FINANCE_HERMES_API_KEY only; Ollama defaults in 14 §6 (legacy: 127.0.0.1:11434, qwen2.5:0.5b). |
# | 1.0     | 2026-05-19 | Secrets-only template (14 §1.4). Explicit Redis: FINANCE_REDIS__HOST, PORT, DB, PASSWORD (setup: 11 §7.1). Mail/SMTP per mailbox in mail_gateway_config, not .env. SendGrid: FINANCE_SENDGRID__API_KEY only. Cross-ref 14 v2.4, 11 v2.5. |
#
# PURPOSE
#   This file is committed to the repository as a template.
#   It lists secrets and other values that MUST be set in .env before deploy.
#   It must never contain real secrets.
#
# WHAT BELONGS HERE
#   - API keys, passwords, encryption keys, connection URLs with credentials
#   - Values that cannot be stored in the database or Admin UI
#
# WHAT DOES NOT BELONG HERE (see 14_Environment_and_Configuration_Reference.md)
#   - Per-mailbox IMAP/SMTP usernames, passwords, or From addresses (accar, accap, …)
#     → mail_gateway_config, edited in Client Admin UI (14 §7.3)
#   - Non-secret defaults (ports, timeouts, feature flags) — use code defaults in 14
#
# SETUP
#   1. Copy to .env:          cp .env.example .env
#   2. Generate secrets:      python scripts/generate-keys.py
#   3. Fill in all [REQUIRED] values before starting the stack.
#   4. Never commit .env — it is in .gitignore.
#
# SOURCE OF TRUTH
#   Variable definitions, types, defaults, and validation rules are in:
#   14_Environment_and_Configuration_Reference.md (v2.5) — Ollama §6, Hermes §6b
#   11_Deployment_Operations_Runbook.md (v2.5) — Redis §7.1
#
# ALL VARIABLES use the FINANCE_ prefix. Nested settings use __ delimiter.
# Example: FINANCE_DATABASE__POOL_SIZE maps to settings.database.pool_size
# ============================================================================


# ----------------------------------------------------------------------------
# 1. APPLICATION
# ----------------------------------------------------------------------------
FINANCE_APP_NAME=AI Finance Platform
FINANCE_APP_ENV=development          # development | staging | production
FINANCE_DEBUG=false
FINANCE_LOG_LEVEL=INFO               # DEBUG | INFO | WARNING | ERROR | CRITICAL
FINANCE_HOST=0.0.0.0
FINANCE_PORT=8000
FINANCE_WORKERS=4                    # Uvicorn worker count (production only)


# ----------------------------------------------------------------------------
# 2. DATABASE (Supabase PostgreSQL)
# ----------------------------------------------------------------------------
# [REQUIRED] Format: postgresql+asyncpg://user:password@host:5432/dbname
# Alembic strips +asyncpg and replaces with +psycopg2 for migrations.
FINANCE_DATABASE_URL=postgresql+asyncpg://postgres:[PASSWORD]@db.ehsoeyfopazodvmpkkpy.supabase.co:5432/postgres
FINANCE_DATABASE__POOL_SIZE=20
FINANCE_DATABASE__MAX_OVERFLOW=10
FINANCE_DATABASE__POOL_TIMEOUT=30
FINANCE_DATABASE__POOL_RECYCLE=1800
FINANCE_DATABASE__ECHO=false         # Set true to log all SQL (dev only)

# Note: POSTGRES_PASSWORD is NOT required — database is managed by Supabase Cloud.
# The password is embedded in FINANCE_DATABASE_URL above and managed via the Supabase
# dashboard (Project Settings → Database → Database password). Do not set this variable.


# ----------------------------------------------------------------------------
# 3. REDIS — password: you generate it; same value in redis.conf requirepass (11 §7.1)
# ----------------------------------------------------------------------------
FINANCE_REDIS__HOST=redis              # Docker Compose service; use localhost for local dev
FINANCE_REDIS__PORT=6379
FINANCE_REDIS__DB=0                    # Logical database index (0–15)
FINANCE_REDIS__PASSWORD=[REQUIRED]     # Generate: openssl rand -base64 32
# Optional legacy single URL (overrides host/port/db if set): redis://host:port/db
# FINANCE_REDIS_URL=redis://redis:6379/0
# Timeouts / TLS defaults: 14_Environment_and_Configuration_Reference.md §5


# ----------------------------------------------------------------------------
# 4. OLLAMA / AI — defaults in 14 §6 (not listed here unless overriding)
# ----------------------------------------------------------------------------
# Target (Docker): FINANCE_AI__OLLAMA_BASE_URL=http://ollama:11434
#                 FINANCE_AI__OLLAMA_MODEL=hermes3 (+ qwen2.5 fallbacks per 04 §8.4)
# Legacy (accounting_agent.py): http://127.0.0.1:11434/api/generate, model qwen2.5:0.5b — no Hermes
# Reference README does not document Ollama env vars.


# ----------------------------------------------------------------------------
# 5. HERMES (AI orchestration — secret only)
# ----------------------------------------------------------------------------
# Generate: openssl rand -hex 32  (must match HERMES_API_KEY in docker-compose — 14 §6b.1, 04 §2.1)
FINANCE_HERMES_API_KEY=[REQUIRED]
# FINANCE_HERMES_BASE_URL=http://hermes:8001   # default internal URL — 14 §6b


# ----------------------------------------------------------------------------
# 6. MAIL (Inbound / Outbound mailboxes)
# ----------------------------------------------------------------------------
# No mailbox-specific variables here. Each mailbox (accar, accap, acc, …) is
# configured in mail_gateway_config — addresses, IMAP credentials, and From names
# via Client Admin UI (14 §7.3, 06 §7.3). Passwords are encrypted with
# FINANCE_PRIVACY_ENCRYPTION_KEY (section 10 below).
# Optional global overrides (host, port, poll interval): 14 §7.1 — defaults apply if unset.


# ----------------------------------------------------------------------------
# 7. SUPABASE
# ----------------------------------------------------------------------------
# [REQUIRED] Supabase Cloud project — project ref: ehsoeyfopazodvmpkkpy
FINANCE_SUPABASE__URL=https://ehsoeyfopazodvmpkkpy.supabase.co
# [REQUIRED] From: Supabase Dashboard → Project Settings → API → service_role key
FINANCE_SUPABASE__SERVICE_KEY=[REQUIRED]
# [REQUIRED] From: Supabase Dashboard → Project Settings → API → JWT Secret
# Distinct from FINANCE_JWT__SECRET — generate and store independently
FINANCE_SUPABASE__JWT_SECRET=[REQUIRED]
# Not required (server-side platform) — leave commented unless client-side use is added
# FINANCE_SUPABASE__ANON_KEY=
FINANCE_SUPABASE__STORAGE_BUCKET=finance-attachments


# ----------------------------------------------------------------------------
# 8. PUBLIC HOSTNAMES & TLS (bp0.work — see 14 §2.7, §9.0)
# ----------------------------------------------------------------------------
FINANCE_PUBLIC__API_HOST=api.bp0.work
FINANCE_PUBLIC__APP_HOST=finance.bp0.work
FINANCE_PUBLIC__PLATFORM_ADMIN_HOST=admin.bp0.work
FINANCE_PUBLIC__CLIENT_ADMIN_HOST=mmlogistix-admin.bp0.work
FINANCE_PUBLIC__TRAEFIK_DASHBOARD_HOST=traefik.bp0.work
FINANCE_LETS_ENCRYPT_EMAIL=admin@bp0.work
# FINANCE_LETS_ENCRYPT_CA_SERVER=https://acme-staging-v02.api.letsencrypt.org/directory  # testing only

# ----------------------------------------------------------------------------
# 8b. FINANCE ACTIVITY LOG (daily digest — see 11 §17.5, 17 §10.7, 06 §7.4.1)
# Email + Wasabi: finance_daily_{YYYY-MM-DD}.csv (RFC 4180)
# ----------------------------------------------------------------------------
FINANCE_DAILY_LOG_RECIPIENT=cfo.mmlogistix@bp0.work
FINANCE_DAILY_LOG_TIMEZONE=Asia/Singapore
FINANCE_DAILY_LOG__CSV_UTF8_BOM=true

# ----------------------------------------------------------------------------
# 8c. SCHEDULER & MAIL ACTION TOKENS (05 §19.1, §8.8a)
# ----------------------------------------------------------------------------
# [REQUIRED] Bearer for POST /internal/jobs/finance-daily-log (11 §17.5)
FINANCE_INTERNAL_CRON__TOKEN=[REQUIRED]
# [REQUIRED] HMAC for signed Approve/Reject/Escalate email links; may use FINANCE_HASH_SECRET if unset
FINANCE_MAIL_ACTION__SECRET=[REQUIRED]

# ----------------------------------------------------------------------------
# 8d. WASABI (bp0work accounts bucket — see 14 §2.9, 06 §7.5, 11 §15.4)
# ----------------------------------------------------------------------------
# [REQUIRED] IAM-scoped to bucket bp0workacc only
FINANCE_WASABI__ACCESS_KEY_ID=[REQUIRED]
FINANCE_WASABI__SECRET_ACCESS_KEY=[REQUIRED]
FINANCE_WASABI__BUCKET=bp0workacc
FINANCE_WASABI__ENDPOINT_URL=https://s3.ap-southeast-1.wasabisys.com
FINANCE_WASABI__REGION=ap-southeast-1
FINANCE_WASABI__PREFIX_LOGS=logs/
FINANCE_WASABI__PREFIX_BACKUPS=backups/
FINANCE_WASABI__PREFIX_TRANSACTIONS=transactions/
FINANCE_WASABI__ARCHIVE_ON_INTAKE=true

# ----------------------------------------------------------------------------
# 9. TRAEFIK (dashboard basic auth — secret)
# ----------------------------------------------------------------------------
FINANCE_TRAEFIK__ENABLED=true
FINANCE_TRAEFIK__DASHBOARD_ENABLED=false
FINANCE_TRAEFIK__DASHBOARD_AUTH=admin:[htpasswd-string]
FINANCE_TRAEFIK__LOG_LEVEL=INFO
FINANCE_TRAEFIK__ACCESS_LOG=true


# ----------------------------------------------------------------------------
# 10. JWT & AUTHENTICATION
# ----------------------------------------------------------------------------
# [REQUIRED] Generate: openssl rand -hex 32
FINANCE_JWT__SECRET=[REQUIRED]
FINANCE_JWT__ALGORITHM=HS256
FINANCE_JWT__ACCESS_TOKEN_EXPIRE_MINUTES=15
FINANCE_JWT__REFRESH_TOKEN_EXPIRE_DAYS=7
FINANCE_JWT__ISSUER=finance-platform
FINANCE_JWT__AUDIENCE=finance-api

# Argon2id — OWASP recommended values; do not lower without security review
FINANCE_ARGON2__TIME_COST=3
FINANCE_ARGON2__MEMORY_COST=65536
FINANCE_ARGON2__PARALLELISM=4

# TOTP
FINANCE_TOTP__ISSUER=mmlogistix-finance


# ----------------------------------------------------------------------------
# 11. ENCRYPTION & PRIVACY
# ----------------------------------------------------------------------------
# [REQUIRED] Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FINANCE_PRIVACY_ENCRYPTION_KEY=[REQUIRED]
FINANCE_BACKUP_ENCRYPTION_KEY=[REQUIRED]
# [REQUIRED] Generate: openssl rand -hex 32
FINANCE_HASH_SECRET=[REQUIRED]


# ----------------------------------------------------------------------------
# 12. MONITORING
# ----------------------------------------------------------------------------
FINANCE_PROMETHEUS__ENABLED=true
FINANCE_PROMETHEUS__PORT=9090
FINANCE_PROMETHEUS__PATH=/metrics
FINANCE_GRAFANA__ENABLED=true
FINANCE_GRAFANA__ADMIN_PASSWORD=[REQUIRED]  # Pydantic Settings access in app code

# ----------------------------------------------------------------------------
# 12a. GRAFANA_ADMIN_PASSWORD — Docker-native variable (no FINANCE_ prefix)
# Adjacent to section 12 (Monitoring); sets companion FINANCE_GRAFANA__ADMIN_PASSWORD above.
# ----------------------------------------------------------------------------
# Docker Compose passes this directly to the Grafana container as
# GF_SECURITY_ADMIN_PASSWORD. It does NOT use the FINANCE_ prefix.
# Set to the same value as FINANCE_GRAFANA__ADMIN_PASSWORD above.
# Generate: openssl rand -base64 32
GRAFANA_ADMIN_PASSWORD=[REQUIRED]

# Optional: Sentry error tracking
# FINANCE_SENTRY__DSN=
# FINANCE_SENTRY__ENVIRONMENT=production


# ----------------------------------------------------------------------------
# 13. RATE LIMITING
# Override defaults from docs/14_Environment_and_Configuration_Reference.md §15
# ----------------------------------------------------------------------------
# FINANCE_RATE_LIMIT__ENABLED=true
# FINANCE_RATE_LIMIT__API_GENERAL_PER_MINUTE=120
# FINANCE_RATE_LIMIT__API_WRITE_PER_MINUTE=60
# FINANCE_RATE_LIMIT__AUTH_LOGIN_PER_MINUTE=5
# FINANCE_RATE_LIMIT__AUTH_2FA_PER_MINUTE=5
# FINANCE_RATE_LIMIT__AI_CLASSIFICATION_PER_MINUTE=30
# FINANCE_RATE_LIMIT__SSE_CONNECTIONS_PER_USER=5


# ----------------------------------------------------------------------------
# 14. TIMEOUTS (seconds)
# Override defaults from docs/14_Environment_and_Configuration_Reference.md §15
# ----------------------------------------------------------------------------
# FINANCE_TIMEOUT__HTTP_REQUEST=30
# FINANCE_TIMEOUT__DB_QUERY=30
# FINANCE_TIMEOUT__AI_GENERATION=120
# FINANCE_TIMEOUT__AI_CLASSIFICATION=60
# FINANCE_TIMEOUT__EMAIL_IMAP=30


# ----------------------------------------------------------------------------
# 15. FEATURE FLAGS
# Override defaults — all features enabled in production unless toggled here
# ----------------------------------------------------------------------------
# FINANCE_FEATURE__ENABLE_STP=true
# FINANCE_FEATURE__ENABLE_AI_CLASSIFICATION=true
# FINANCE_FEATURE__ENABLE_GUARDRAILS=true          # Hermes prompt injection guard + output validation (04_Hermes_Integration_Spec.md §13)
# FINANCE_FEATURE__ENABLE_CASH_FORECASTING=false
# FINANCE_FEATURE__ENABLE_INTERCOMPANY=false
# FINANCE_FEATURE__ENABLE_FX_HEDGING=false

# ----------------------------------------------------------------------------
# 16. SENDGRID (ADMIN UI EMAIL OTP ONLY)
# See: 14_Environment_and_Configuration_Reference.md §7c
# ----------------------------------------------------------------------------
FINANCE_SENDGRID__API_KEY=[REQUIRED]   # SendGrid dashboard → API Keys — never commit
# Verified sender (FROM_EMAIL), OTP TTL, etc.: 14 §7c — not secrets; use defaults or platform config

# ----------------------------------------------------------------------------
# 17. OUTBOUND SMTP (shared relay + notifications)
# See: 14 §7b, docs/18_Notification_Service_Specification.md §10
# ----------------------------------------------------------------------------
# Relay host/port/TLS defaults (bp0.work:465): 14 §7b — override only if needed.
# SMTP auth and From address are per sending mailbox in mail_gateway_config, not .env.
# Dev: set FINANCE_NOTIFICATION__ENABLED=false in .env (see 14 §7b.3)

# ============================================================================
# END OF .env.example
# ============================================================================
